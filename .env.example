# Core
TELEGRAM_BOT_TOKEN=your_token_here
OPENROUTER_API_TOKEN=your_openrouter_key_here

# Runtime
RUN_MODE=webhook
ENV=production
DEBUG=false
PORT=8000

# URLs for Vercel/Replit
WEBHOOK_URL=https://your-vercel-app.vercel.app/webhook
NEXT_PUBLIC_API_BASE=https://your-vercel-app.vercel.app
NEXT_PUBLIC_BOT_USERNAME=yourbotusername_bot
NEXT_PUBLIC_WEBAPP_URL=https://your-vercel-frontend.vercel.app

# Services (use free tiers)
DATABASE_URL=sqlite:///zyraxis.db  # Change to Postgres for prod (Supabase/Neon)
REDIS_URL=redis://your-upstash-redis  # Upstash free tier

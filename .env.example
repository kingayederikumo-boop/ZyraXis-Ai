# Core
TELEGRAM_BOT_TOKEN=your_token_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Optional: separate OpenRouter keys per feature, for independent spend
# limits on OpenRouter's dashboard. Each falls back to OPENROUTER_API_KEY
# above if left unset - safe to ignore until you actually want per-feature
# budget caps.
# OPENROUTER_API_KEY_CHAT=
# OPENROUTER_API_KEY_ROLEPLAY=
# OPENROUTER_API_KEY_CODE=
# OPENROUTER_API_KEY_SEARCH=
# OPENROUTER_API_KEY_IMAGE=
# OPENROUTER_API_KEY_FILE=
# OPENROUTER_API_KEY_VIDEO=

# Optional: fallback model chain for chat/roleplay/code (comma-separated,
# tried in order if one fails). Defaults to a sensible chain if unset.
# OPENROUTER_MODEL_CHAIN=anthropic/claude-sonnet-4.6,openai/gpt-5.4,google/gemini-3.1-pro-preview

# Runtime
ENV=production
DEBUG=false
PORT=8000

# Your actual Vercel production URL + /webhook - the app registers this
# with Telegram automatically on every boot. Check the Vercel dashboard
# for the real current URL, don't guess.
WEBHOOK_URL=https://your-vercel-app.vercel.app/webhook

# Services - production values, from Supabase/Upstash dashboards
DATABASE_URL=postgresql://user:password@db.your-project.supabase.co:5432/postgres
REDIS_URL=redis://your-upstash-redis
